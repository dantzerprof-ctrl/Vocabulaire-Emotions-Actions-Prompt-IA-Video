<title>Direction d'Acteur & Émotions — Prompts IA</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=JetBrains+Mono:wght@300;400;500&family=Unbounded:wght@300;400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f5f0e8;
    --surface: #ede8de;
    --surface2: #e4ddd0;
    --border: #d4cbb8;
    --border-light: #e8e2d4;
    --ink: #1a1710;
    --ink-mid: #3d3928;
    --ink-dim: #7a7260;
    --ink-muted: #a09880;

    --veo: #c8460a;
    --veo-bg: rgba(200,70,10,0.08);
    --veo-border: rgba(200,70,10,0.3);

    --kling: #1a5c9e;
    --kling-bg: rgba(26,92,158,0.08);
    --kling-border: rgba(26,92,158,0.3);

    --mj: #2d7a4a;
    --mj-bg: rgba(45,122,74,0.08);
    --mj-border: rgba(45,122,74,0.3);

    --canvas: #8b3aa8;
    --canvas-bg: rgba(139,58,168,0.08);
    --canvas-border: rgba(139,58,168,0.3);

    --banana: #b8860b;
    --banana-bg: rgba(184,134,11,0.08);
    --banana-border: rgba(184,134,11,0.3);

    --all-border: rgba(26,23,16,0.25);
    --all-bg: rgba(26,23,16,0.04);

    --flash: #c8460a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: 'Cormorant Garamond', Georgia, serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── NOISE TEXTURE ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px;
    pointer-events: none;
    z-index: 9999;
  }

  /* ── HEADER ── */
  header {
    position: relative;
    padding: 4rem 2rem 2.5rem;
    text-align: center;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  header::after {
    content: 'ACTING · PSYCHOLOGIE · DIRECTION';
    position: absolute;
    bottom: -0.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: var(--ink-muted);
    white-space: nowrap;
    pointer-events: none;
  }

  .header-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: var(--ink-muted);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  header h1 {
    font-family: 'Unbounded', sans-serif;
    font-weight: 700;
    font-size: clamp(1.4rem, 3.5vw, 2.4rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 0.4rem;
  }

  header h1 em {
    font-style: italic;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2em;
    font-weight: 300;
    color: var(--veo);
  }

  header .subtitle {
    font-size: 1.1rem;
    font-style: italic;
    color: var(--ink-dim);
    margin-bottom: 2rem;
    font-weight: 300;
  }

  /* ── LEGEND ── */
  .legend {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    max-width: 750px;
    margin: 0 auto 1.5rem;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--ink-dim);
    padding: 0.3rem 0.75rem;
    border-radius: 2px;
    border: 1px solid var(--border);
    background: var(--surface);
    cursor: pointer;
    transition: all 0.18s;
    user-select: none;
    letter-spacing: 0.05em;
  }

  .legend-item:hover { border-color: var(--ink-dim); color: var(--ink); }

  .legend-item.active { color: var(--ink); border-color: var(--ink-mid); background: var(--surface2); }
  .legend-item[data-filter="veo"].active { border-color: var(--veo); background: var(--veo-bg); color: var(--veo); }
  .legend-item[data-filter="kling"].active { border-color: var(--kling); background: var(--kling-bg); color: var(--kling); }
  .legend-item[data-filter="mj"].active { border-color: var(--mj); background: var(--mj-bg); color: var(--mj); }
  .legend-item[data-filter="canvas"].active { border-color: var(--canvas); background: var(--canvas-bg); color: var(--canvas); }
  .legend-item[data-filter="banana"].active { border-color: var(--banana); background: var(--banana-bg); color: var(--banana); }

  .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── SEARCH ── */
  .search-wrap {
    max-width: 500px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .search-wrap input {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-bottom: 2px solid var(--ink-mid);
    color: var(--ink);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    padding: 0.65rem 1rem;
    border-radius: 0;
    outline: none;
    transition: border-color 0.2s;
    letter-spacing: 0.02em;
  }

  .search-wrap input:focus { border-bottom-color: var(--veo); }
  .search-wrap input::placeholder { color: var(--ink-muted); font-style: italic; }

  /* ── MAIN ── */
  main {
    max-width: 1440px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 5rem;
  }

  /* ── SECTION ── */
  .section {
    margin-bottom: 3rem;
  }

  .section-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .section-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem;
    font-weight: 300;
    font-style: italic;
    color: var(--border);
    line-height: 1;
    width: 3rem;
    text-align: center;
  }

  .section-info {}

  .section-title {
    font-family: 'Unbounded', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  .section-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.95rem;
    font-style: italic;
    color: var(--ink-muted);
    margin-top: 0.1rem;
  }

  .section-line {
    height: 1px;
    background: var(--border);
  }

  .section-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: var(--ink-muted);
    white-space: nowrap;
  }

  /* ── GRID ── */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 0.5rem;
  }

  /* ── CARD ── */
  .term {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border-light);
    border-left: 3px solid var(--border);
    padding: 0.8rem 1rem 0.8rem 1rem;
    cursor: pointer;
    transition: all 0.15s ease;
    overflow: hidden;
  }

  .term:hover {
    background: var(--surface2);
    border-left-color: var(--ink-mid);
    transform: translateX(2px);
    box-shadow: -4px 4px 16px rgba(26,23,16,0.08);
  }

  /* platform left-border colors */
  .term.veo { border-left-color: var(--veo-border); }
  .term.veo:hover { border-left-color: var(--veo); }
  .term.kling { border-left-color: var(--kling-border); }
  .term.kling:hover { border-left-color: var(--kling); }
  .term.mj { border-left-color: var(--mj-border); }
  .term.mj:hover { border-left-color: var(--mj); }
  .term.canvas { border-left-color: var(--canvas-border); }
  .term.canvas:hover { border-left-color: var(--canvas); }
  .term.banana { border-left-color: var(--banana-border); }
  .term.banana:hover { border-left-color: var(--banana); }
  .term.all { border-left-color: var(--border); }
  .term.all:hover { border-left-color: var(--ink-mid); }

  /* top row */
  .term-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.2rem;
  }

  .term-en {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: 0.02em;
    line-height: 1.3;
  }

  .term-fr {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.95rem;
    font-style: italic;
    color: var(--ink-dim);
    line-height: 1.3;
    margin-bottom: 0.3rem;
  }

  .term-desc {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.85rem;
    color: var(--ink-muted);
    line-height: 1.5;
  }

  .term-source {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.55rem;
    color: var(--ink-muted);
    background: rgba(26,23,16,0.05);
    border: 1px solid var(--border);
    padding: 1px 5px;
    border-radius: 2px;
    margin-top: 0.4rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* badges */
  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 3px;
    flex-shrink: 0;
    max-width: 110px;
    justify-content: flex-end;
  }

  .badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.52rem;
    font-weight: 500;
    padding: 1px 4px;
    border-radius: 1px;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .badge.veo { background: var(--veo-bg); color: var(--veo); border: 1px solid var(--veo-border); }
  .badge.kling { background: var(--kling-bg); color: var(--kling); border: 1px solid var(--kling-border); }
  .badge.mj { background: var(--mj-bg); color: var(--mj); border: 1px solid var(--mj-border); }
  .badge.canvas { background: var(--canvas-bg); color: var(--canvas); border: 1px solid var(--canvas-border); }
  .badge.banana { background: var(--banana-bg); color: var(--banana); border: 1px solid var(--banana-border); }

  /* copy flash */
  .copy-hint {
    position: absolute;
    right: 0.6rem;
    bottom: 0.6rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.58rem;
    color: var(--ink-muted);
    opacity: 0;
    transition: opacity 0.2s;
    letter-spacing: 0.05em;
  }
  .term:hover .copy-hint { opacity: 0.7; }

  .term.copied {
    border-left-color: var(--flash) !important;
    background: rgba(200,70,10,0.05) !important;
  }

  .term.copied::after {
    content: '✓ copié dans le presse-papier';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(200,70,10,0.07);
    color: var(--flash);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    pointer-events: none;
    border-radius: 0;
  }

  /* hidden */
  .term.hidden { display: none; }
  .section.hidden { display: none; }

  /* ── TOAST ── */
  #toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: var(--ink);
    color: var(--bg);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 400;
    padding: 0.55rem 1.3rem;
    border-radius: 2px;
    letter-spacing: 0.1em;
    transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
    z-index: 9998;
    pointer-events: none;
    white-space: nowrap;
  }

  #toast.show { transform: translateX(-50%) translateY(0); }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); }

  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; }
    .section-num { display: none; }
    header { padding: 2rem 1rem 2rem; }
  }

  /* ── DECORATIVE DIVIDER ── */
  .ornament {
    text-align: center;
    color: var(--border);
    font-size: 1rem;
    letter-spacing: 1rem;
    margin: 0 auto 1.5rem;
    user-select: none;
  }
</style>
</head>
