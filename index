// ═══════════════════════════════════════════════════════════════════════════
// RENDER
// ═══════════════════════════════════════════════════════════════════════════
const main = document.getElementById('main');

function platformClass(platforms) {
  if (platforms.includes('all') || platforms.length >= 4) return 'all';
  return platforms[0];
}

function buildBadges(platforms) {
  if (platforms.includes('all')) return '';
  return `<div class="badges">${platforms.map(p => `<span class="badge ${p}">${p === 'mj' ? 'MJ' : p === 'banana' ? 'BANANA' : p === 'canvas' ? 'CANVAS' : p.toUpperCase()}</span>`).join('')}</div>`;
}

SECTIONS.forEach((section, idx) => {
  const sec = document.createElement('div');
  sec.className = 'section';
  sec.dataset.sectionId = idx;

  sec.innerHTML = `
    <div class="section-header">
      <div class="section-num">${section.num}</div>
      <div class="section-info">
        <div class="section-title">${section.icon} ${section.title}</div>
        <div class="section-subtitle">${section.subtitle}</div>
      </div>
      <div class="section-line" style="display:none"></div>
      <div class="section-count">${section.terms.length} termes</div>
    </div>`;

  const grid = document.createElement('div');
  grid.className = 'grid';

  section.terms.forEach(term => {
    const cls = term.platforms.includes('all') || term.platforms.length >= 4 ? 'all' : term.platforms[0];
    const card = document.createElement('div');
    card.className = `term ${cls}`;
    card.dataset.en = term.en.toLowerCase();
    card.dataset.fr = term.fr.toLowerCase();
    card.dataset.desc = (term.desc || '').toLowerCase();
    card.dataset.platforms = term.platforms.join(',');
    card.dataset.source = term.source;

    card.innerHTML = `
      <div class="term-top">
        <div class="term-en">${term.en}</div>
        ${buildBadges(term.platforms)}
      </div>
      <div class="term-fr">${term.fr}</div>
      ${term.desc ? `<div class="term-desc">${term.desc}</div>` : ''}
      ${term.source ? `<span class="term-source">${SOURCE_LABELS[term.source] || term.source}</span>` : ''}
      <span class="copy-hint">⎘ copier</span>
    `;

    card.addEventListener('click', () => copyCard(card, term.en));
    grid.appendChild(card);
  });

  sec.appendChild(grid);
  main.appendChild(sec);
});

// ═══════════════════════════════════════════════════════════════════════════
// COPY
// ═══════════════════════════════════════════════════════════════════════════
const toast = document.getElementById('toast');
let toastT;

function copyCard(card, text) {
  navigator.clipboard.writeText(text).catch(() => {
    const ta = document.createElement('textarea');
    ta.value = text;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
  });
  card.classList.add('copied');
  setTimeout(() => card.classList.remove('copied'), 1100);
  toast.classList.add('show');
  clearTimeout(toastT);
  toastT = setTimeout(() => toast.classList.remove('show'), 1800);
}

// ═══════════════════════════════════════════════════════════════════════════
// FILTER
// ═══════════════════════════════════════════════════════════════════════════
let activeFilter = 'all';

document.querySelectorAll('.legend-item').forEach(btn => {
  btn.addEventListener('click', () => {
    activeFilter = btn.dataset.filter;
    document.querySelectorAll('.legend-item').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    applyFilters();
  });
});

document.getElementById('search').addEventListener('input', applyFilters);

function applyFilters() {
  const q = document.getElementById('search').value.toLowerCase().trim();

  document.querySelectorAll('.term').forEach(card => {
    const platformMatch = activeFilter === 'all' || card.dataset.platforms.includes(activeFilter);
    const searchMatch = !q ||
      card.dataset.en.includes(q) ||
      card.dataset.fr.includes(q) ||
      card.dataset.desc.includes(q) ||
      card.dataset.source.includes(q);
    card.classList.toggle('hidden', !(platformMatch && searchMatch));
  });

  document.querySelectorAll('.section').forEach(sec => {
    const hasVisible = [...sec.querySelectorAll('.term')].some(c => !c.classList.contains('hidden'));
    sec.classList.toggle('hidden', !hasVisible);
  });
}
